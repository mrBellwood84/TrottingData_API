@API_HostAddress = http://localhost:5007

### 1. Get all Driver IDs (Expected: 403 Forbidden)
# Blocked by model policy
GET {{API_HostAddress}}/model/driver/id
Accept: application/json

> {%
    client.test("Should block bulk ID retrieval", function () {
        client.assert(response.status === 403, "Expected HTTP 403 Forbidden due to security policy");
    });
%}


### 2. Get simple Driver entity by ID (Expected: 200 OK)
< {%
    client.global.set("driver_id", "09be28e0-00ec-461e-bf20-5fa5a3af4dec");
%}
GET {{API_HostAddress}}/model/driver/entity/{{driver_id}}
Accept: application/json

> {%
    client.test("Should return simple driver entity by ID", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(response.body.id === client.global.get("driver_id"), "ID mismatch");
    });
%}


### 3. Get complex Driver entity by ID (Expected: 200 OK)
< {%
    client.global.set("driver_id", "09be28e0-00ec-461e-bf20-5fa5a3af4dec");
%}
GET {{API_HostAddress}}/model/driver/complex/{{driver_id}}
Accept: application/json

> {%
    client.test("Should return complex driver entity by ID", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(response.body.id === client.global.get("driver_id"), "ID mismatch");
    });
%}


### 4. Get simple Driver entity by external Source ID (Expected: 200 OK)
< {%
    client.global.set("driver_source_id", "30016511");
%}
GET {{API_HostAddress}}/model/driver/entity/source/{{driver_source_id}}
Accept: application/json

> {%
    client.test("Should return simple driver entity by Source ID", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(response.body.sourceId === client.global.get("driver_source_id"), "Source ID mismatch");
    });
%}


