@API_HostAddress = http://localhost:5007

### 1. Get all Driver License IDs (Expected: 200 OK)
# Retrieves all available IDs and stores the first one dynamically for subsequent tests
GET {{API_HostAddress}}/model/driverlicense/id
Accept: application/json

> {%
    client.test("Should retrieve all driver license IDs successfully", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(response.body.length > 0, "Expected to find at least one ID");

        // Extract and set global ID dynamically
        client.global.set("driver_license_id", response.body[0].id);
    });
%}


### 2. Get all simple Driver License entities (Expected: 200 OK)
GET {{API_HostAddress}}/model/driverlicense/entity
Accept: application/json

> {%
    client.test("Should retrieve all simple driver license entities successfully", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(Array.isArray(response.body), "Expected response body to be an array");
    });
%}


### 3. Get simple Driver License entity by ID (Expected: 200 OK)
GET {{API_HostAddress}}/model/driverlicense/entity/{{driver_license_id}}
Accept: application/json

> {%
    client.test("Should retrieve single simple driver license by ID", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(response.body.id === client.global.get("driver_license_id"), "ID mismatch");
    });
%}


### 4. Get all complex Driver License entities (Expected: 200 OK)
GET {{API_HostAddress}}/model/driverlicense/complex
Accept: application/json

> {%
    client.test("Should retrieve all complex driver license entities successfully", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(Array.isArray(response.body), "Expected response body to be an array");
    });
%}


### 5. Get complex Driver License entity by ID (Expected: 200 OK)
GET {{API_HostAddress}}/model/driverlicense/complex/{{driver_license_id}}
Accept: application/json

> {%
    client.test("Should retrieve single complex driver license by ID", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(response.body.id === client.global.get("driver_license_id"), "ID mismatch");
    });
%}


### 6. Test 404 behavior for non-existing ID
GET {{API_HostAddress}}/model/driverlicense/complex/00000000-0000-0000-0000-000000000000
Accept: application/json

> {%
    client.test("Request should return 404 NotFound", function () {
        client.assert(response.status === 404, "Expected HTTP 404 NotFound");
    });
%}