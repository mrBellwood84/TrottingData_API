@API_HostAddress = http://localhost:5007

### 1. Get simple Horse entity by ID - Standard (Expected: 200 OK)
< {%
    client.global.set("horse_id", "000049b2-f0a0-4972-839c-bb279b99a84b");
%}
GET {{API_HostAddress}}/model/horse/entity/{{horse_id}}
Accept: application/json

> {%
    client.test("Should return simple horse entity by ID", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(response.body.id === client.global.get("horse_id"), "ID mismatch");
    });
%}


### 2. Get complex Horse entity by ID - Standard (Expected: 200 OK)
< {%
    client.global.set("horse_id", "000049b2-f0a0-4972-839c-bb279b99a84b");
%}
GET {{API_HostAddress}}/model/horse/complex/{{horse_id}}
Accept: application/json

> {%
    client.test("Should return complex horse entity by ID", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(response.body.id === client.global.get("horse_id"), "ID mismatch");
    });
%}


### 3. Get complex Horse entity by ID - Minimal data / null fields (Expected: 200 OK)
# Verifies that horses with missing or null fields (e.g. sex, type, name, birth year) are handled gracefully
< {%
    client.global.set("minimal_horse_id", "0090fb4a-5d74-4f93-9071-da28a8f75715");
%}
GET {{API_HostAddress}}/model/horse/complex/{{minimal_horse_id}}
Accept: application/json

> {%
    client.test("Should return complex minimal horse entity by ID even with null values", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK despite null/missing database values");
        client.assert(response.body.id === client.global.get("minimal_horse_id"), "ID mismatch");
    });
%}


### 4. Get simple Horse entity by external Source ID - Standard (Expected: 200 OK)
< {%
    client.global.set("horse_source_id", "75200221S080356");
%}
GET {{API_HostAddress}}/model/horse/entity/source/{{horse_source_id}}
Accept: application/json

> {%
    client.test("Should return simple horse entity by Source ID", function () {
        client.assert(response.status === 200, "Expected HTTP 200 OK");
        client.assert(response.body.sourceId === client.global.get("horse_source_id"), "Source ID mismatch");
    });
%}


