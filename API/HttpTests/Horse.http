    });
%}


### 7. Get all simple Horse entities (Expected: 404 Not Found)
# Verified: Route does not exist on this controller
GET {{API_HostAddress}}/model/horse/entity
Accept: application/json

> {%
    client.test("Should return 404 as bulk simple entities route does not exist", function () {
        client.assert(response.status === 404, "Expected HTTP 404 Not Found");
    });
%}


